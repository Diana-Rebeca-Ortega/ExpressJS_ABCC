<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Detalle de Alumno</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <style>
    .negrita { font-weight: bold; color: #333; }
    .dato-alumno { margin-bottom: 15px; padding: 10px; background-color: #f8f9fa; border-radius: 5px; border-left: 4px solid #0d6efd; }
  </style>
</head>

<body>

  <header>
    <nav class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">
          <img src="/public/assets/images/estudiantes.png" class="img-fluid" style="max-height: 40px;">
        </a>
      </div>
    </nav>
  </header>

  <div class="container mt-5 pt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        
        <nav aria-label="breadcrumb" class="mt-3">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Alumnos</a></li>
            <li class="breadcrumb-item active" aria-current="page">Detalle del Registro</li>
          </ol>
        </nav>

        <div class="card shadow">
          <div class="card-header bg-primary text-white">
            <h2 class="mb-0">INFORMACIÓN DEL ALUMNO</h2>
          </div>
          <div class="card-body">
            
            <div class="row">
              <div class="col-md-6">
                <div class="dato-alumno">
                  <span class="negrita d-block">Número de Control:</span>
                  <span id="num_control">Cargando...</span>
                </div>
              </div>
              <div class="col-md-6">
                <div class="dato-alumno">
                  <span class="negrita d-block">Semestre:</span>
                  <span id="semestre">Cargando...</span>
                </div>
              </div>
            </div>

            <div class="dato-alumno">
              <span class="negrita d-block">Nombre Completo:</span>
              <span id="nombre_completo">Cargando...</span>
            </div>

            <div class="dato-alumno">
              <span class="negrita d-block">Carrera:</span>
              <span id="carrera">Cargando...</span>
            </div>

            <div class="dato-alumno">
              <span class="negrita d-block">Fecha de Nacimiento:</span>
              <span id="fecha_nac">Cargando...</span>
            </div>

            <div class="mt-4 text-center">
              <a href="/" class="btn btn-warning">Volver a la Lista</a>
              <button onclick="window.print()" class="btn btn-secondary">Imprimir Ficha</button>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="text-muted mt-5 mb-3 text-center">
    <hr>
    <p>Instituto Tecnológico Superior de Jerez - Sistemas Computacionales</p>
  </footer>
<script type="text/javascript">
    var url = new URL(window.location.href);
    const id = url.searchParams.get("id");

    if (id) {
        fetch("/alumnos/" + id)
            .then(response => {
                if (response.ok) return response.json();
            })
            .then(data => {
                if (data && data.length > 0) {
                    const a = data[0]; 
                    
                    document.getElementById("num_control").innerText = a.NumControl;
                    document.getElementById("nombre_completo").innerText = a.Nombre + " " + a.PrimerAp + " " + (a.SegundoAp || "");
                    document.getElementById("carrera").innerText = a.Carrera;
                    document.getElementById("semestre").innerText = a.Semestre + "° Semestre";
                   if(a.FechaNac) {
                        const fecha = new Date(a.FechaNac);
                        document.getElementById("fecha_nac").innerText = fecha.toLocaleDateString();
                    }
                } else {
                    console.log("No se encontraron datos para este ID");
                }
            })
            .catch(err => console.error("Error en el fetch:", err));
    }
</script>

</body>
</html>