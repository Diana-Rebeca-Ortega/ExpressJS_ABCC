<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Alumno</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .negrita { font-weight: bold; }
        .card-header { background-color: #ffc107; color: black; } 
    </style>
</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header text-center">
                        <h3 class="mb-0">MODIFICAR REGISTRO DE ALUMNO</h3>
                    </div>
                    <div class="card-body">
                        <form id="formEditar">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="NumControl" class="negrita">Número de Control:</label>
                                    <input type="text" id="NumControl" name="NumControl" class="form-control" readonly>
                                    <small class="text-muted">El número de control no se puede modificar.</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="Semestre" class="negrita">Semestre:</label>
                                    <input type="number" id="Semestre" name="Semestre" class="form-control" min="1" max="12" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="Nombre" class="negrita">Nombre(s):</label>
                                <input type="text" id="Nombre" name="Nombre" class="form-control" required>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="PrimerAp" class="negrita">Primer Apellido:</label>
                                    <input type="text" id="PrimerAp" name="PrimerAp" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="SegundoAp" class="negrita">Segundo Apellido:</label>
                                    <input type="text" id="SegundoAp" name="SegundoAp" class="form-control">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="FechaNac" class="negrita">Fecha de Nacimiento:</label>
                                <input type="date" id="FechaNac" name="FechaNac" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label for="Carrera" class="negrita">Carrera:</label>
                                <select id="Carrera" name="Carrera" class="form-select" required>
                                    <option value="ISC">Ingeniería en Sistemas Computacionales</option>
                                    <option value="Sistemas">Sistemas</option>
                                    <option value="Mecatrónica">Mecatrónica</option>
                                    <option value="Gestión">Gestión Empresarial</option>
                                </select>
                            </div>

                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-warning negrita">ACTUALIZAR DATOS</button>
                                <a href="/" class="btn btn-secondary">CANCELAR</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const id = urlParams.get('id');

   if (id) {
    fetch(`/alumnos/${id}`)
        .then(res => res.json())
        .then(data => {
          
            const a = Array.isArray(data) ? data[0] : data;

            if (a && (a.NumControl || a.numcontrol)) { 
              
                document.getElementById("NumControl").value = a.NumControl || a.numcontrol;
                document.getElementById("Nombre").value = a.Nombre || "";
                document.getElementById("PrimerAp").value = a.PrimerAp || "";
                document.getElementById("SegundoAp").value = a.SegundoAp || "";
                document.getElementById("Semestre").value = a.Semestre || "";
                document.getElementById("Carrera").value = a.Carrera || "";
                
                if (a.FechaNac) {
                    const fecha = new Date(a.FechaNac).toISOString().split('T')[0];
                    document.getElementById("FechaNac").value = fecha;
                }
            } else {
                console.error("No se encontraron datos para el alumno o el formato es incorrecto", data);
            }
        })
        .catch(err => console.error("Error al cargar datos:", err));
}

        document.getElementById("formEditar").onsubmit = function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const datos = Object.fromEntries(formData.entries());

            fetch(`/alumnos/${id}`, {
                method: 'PUT', // Método para actualizar
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            })
            .then(res => {
                if (res.ok) {
                    alert("Alumno actualizado correctamente");
                    window.location.href = "/";
                } else {
                    alert("Error al actualizar");
                }
            })
            .catch(err => console.error("Error:", err));
        };
    </script>
</body>
</html>